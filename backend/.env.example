# Copy to .env for local development. On Render, set these in the service dashboard.

# --- PostgreSQL (local dev only — do not commit .env) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=mdms

# Render (set automatically when Postgres is linked; do not use 127.0.0.1):
# DATABASE_URL=postgresql://user:pass@dpg-xxxxx-a.oregon-postgres.render.com:5432/mdms
# POSTGRES_HOST=dpg-xxxxx-a.oregon-postgres.render.com
# POSTGRES_PORT=5432
# POSTGRES_USER=mdqm
# POSTGRES_PASSWORD=...
# POSTGRES_DB=mdms

# --- App / deployment ---
ENV=development
# CORS_ORIGINS=http://localhost:5173,https://analytix-hub-technologies-pvt-ltd.github.io
MDQM_FRONTEND_URL=http://localhost:5173

# --- Auth / RBAC ---
JWT_SECRET=change-me-in-production
MDQM_BOOTSTRAP_SECRET=your-bootstrap-secret
ACCESS_REQUEST_NOTIFY_EMAIL=you@example.com

# Sync passwords for existing users in auth/demo_users.py (by email only; never creates users).
# Local dev: on by default. Production (Render): set MDQM_SEED_DEMO_USERS=1 in the dashboard.
MDQM_SEED_DEMO_USERS=1

# Legacy first-run admin (only when MDQM_SEED_DEMO_USERS=0 and the users table is empty)
MDQM_DEFAULT_ADMIN_EMAIL=admin@mdqm.local
MDQM_DEFAULT_ADMIN_USERNAME=admin
MDQM_DEFAULT_ADMIN_PASSWORD=changeme
MDQM_DEFAULT_ADMIN_FULL_NAME=MDQM Administrator

# --- Microsoft Graph (email invites / notifications) ---
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_SENDER_EMAIL=

# --- SharePoint export (optional) ---
SP_TENANT_ID=
SP_CLIENT_ID=
SP_CLIENT_SECRET=
SP_DRIVE_ID=
SP_FOLDER_PATH=MDQM-Exports

# --- Encrypted storage for DB passwords (saved connection profiles + “refresh from database” on jobs) ---
# REQUIRED if you type a database password in the UI: the API encrypts it and stores it in Postgres (saved
# connections table and/or job config) so Refresh and saved profiles work without re-entering the password.
# Use a long random string; keep it secret and back it up — changing it invalidates stored ciphertext.
# MDQM_DB_SOURCE_MASTER_SECRET=
